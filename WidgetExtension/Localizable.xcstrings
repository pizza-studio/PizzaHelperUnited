        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profil nicht gefunden. Bitte fügen Sie ein lokales Profil hinzu oder versuchen Sie, das Gerät neu zu starten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profile not found. Please add a local profile or try restarting the device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perfil no encontrado Por favor agrega un perfil local o intenta reiniciar el dispositivo"
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hindi makita ang profile. Mangyaring magdagdag ng lokal na profile o subukang i-restart ang device."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profil introuvable, veuillez ajouter un profil local ou essayer de redémarrer l'appareil"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Profilo non trovato. Si prega di aggiungere un profilo locale o provare a riavviare il dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ご指定できるプロフィールはなさそうです。アプリで登録するか、あるいはこの端末を再起動してみてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "프로필을 찾을 수 없습니다. 로컬 프로필을 추가하거나 기기를 다시 시작해 보세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Профиль не найден Пожалуйста, добавьте локальный профиль или попробуйте перезагрузить устройство"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Không tìm thấy hồ sơ. Vui lòng thêm hồ sơ cục bộ hoặc thử khởi động lại thiết bị."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "尚未发现本地账号。请在 App 内添加、或者重新启动该设备。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "尚未發現本機帳號。請在應用內添加、或者重新啟動該裝置。"
          }
        }
      }
    },
