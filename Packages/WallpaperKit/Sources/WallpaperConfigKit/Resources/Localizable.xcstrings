    "userWallpaperMgr.navDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benutzerdefinierte Hintergründe sind nur für Desktop-Widgets für iOS und macOS verfügbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
